# Шаблон переменных окружения. Скопируй в .env и при необходимости поправь.
# Этап 0 — только база данных. Остальные ключи добавятся на следующих этапах.

# PostgreSQL (локально поднимается через `pnpm db:up`, см. docker-compose.yml)
DATABASE_URL="postgresql://vanmark:vanmark@localhost:5432/vanmark?schema=public"

# Появятся позже (оставлены для ориентира, см. ARCHITECTURE §9):
# AUTH_SECRET=                 # Этап 1 — Auth.js (openssl rand -base64 32)
# VAPID_PUBLIC_KEY=            # Этап 5 — web-push
# VAPID_PRIVATE_KEY=           # Этап 5 — web-push
# UPLOADS_DIR=./data/uploads   # Этап 4 — хранение фото
