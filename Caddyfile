# Caddy: терминация HTTPS и реверс-прокси на app:3000 (ARCHITECTURE §9).
# Домен берётся из переменной окружения DOMAIN (см. docker-compose.prod.yml). TLS-сертификат
# Caddy получает и продлевает автоматически (Let's Encrypt) — нужна A-запись DOMAIN → IP сервера.
{$DOMAIN} {
	encode zstd gzip

	# Жёсткий внешний предел размера тела запроса (preflight-аудит В1): загрузка фото буферизуется
	# приложением в память, а на VPS 1 ядро/1.9 ГБ это DoS-вектор. Caddy режет тело на уровне прокси,
	# не доходя до Node. 16 МБ = лимит вложения (15 МБ, attachments.ts) + запас на multipart-обвязку.
	request_body {
		max_size 16MB
	}

	# Заголовки безопасности (preflight-аудит В6). Применяются ко всем ответам.
	header {
		# HSTS: Caddy и так редиректит http→https, фиксируем строгий транспорт на год.
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Анти-MIME-sniffing глобально (раздача вложений ставит свой nosniff дополнительно).
		X-Content-Type-Options "nosniff"
		# Анти-кликджекинг: ни доска диспетчера, ни PWA водителя не встраиваются в чужой iframe.
		X-Frame-Options "DENY"
		Referrer-Policy "same-origin"
		# CSP: главное — frame-ancestors 'none' (кликджекинг) и object-src 'none'. script/style с
		# 'unsafe-inline' — Next и PWA используют инлайн-бутстрап без nonce (middleware-nonce у нас нет),
		# поэтому строже нельзя без поломки гидрации/SW. img/connect/worker — свой origin (+ data/blob
		# для иконок и фото из офлайн-очереди в IndexedDB).
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; worker-src 'self'; manifest-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; object-src 'none'"
		# Не раскрываем версию сервера.
		-Server
	}

	reverse_proxy app:3000
}
