# Шаблон прод-окружения vanmark-drive. На сервере скопировать в .env рядом с docker-compose.prod.yml
# и заполнить. В репозиторий .env НЕ коммитится (см. .gitignore). Секреты генерируются на сервере:
#   AUTH_SECRET / POSTGRES_PASSWORD : openssl rand -base64 32
#   VAPID-пара                      : npx web-push generate-vapid-keys

# --- PostgreSQL (контейнер postgres из docker-compose.prod.yml) ---
POSTGRES_USER=vanmark
POSTGRES_PASSWORD=__СГЕНЕРИРОВАТЬ__
POSTGRES_DB=vanmark
# Хост = имя сервиса в compose (postgres), а не localhost.
DATABASE_URL="postgresql://vanmark:__ТОТ_ЖЕ_POSTGRES_PASSWORD__@postgres:5432/vanmark?schema=public"

# --- Auth.js ---
AUTH_SECRET=__СГЕНЕРИРОВАТЬ__
AUTH_TRUST_HOST=true

# --- Сид прод-учёток (prisma/seed.ts). Можно один общий пароль (SEED_PASSWORD) либо
#     индивидуальные на логин: SEED_PASSWORD_<LOGIN в верхнем регистре>. Индивидуальные приоритетнее. ---
SEED_PASSWORD=__СГЕНЕРИРОВАТЬ__
# SEED_PASSWORD_ARTEM=...
# SEED_PASSWORD_MILENA=...
# SEED_PASSWORD_KASHIRSKIY=...
# SEED_PASSWORD_PISAREV=...

# --- Фото-отчёты (том uploads) ---
UPLOADS_DIR=/data/uploads

# --- Web Push (VAPID). Публичный ключ дублируется в NEXT_PUBLIC_ (уходит в браузер на сборке). ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@van-mark.ru
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Планировщик напоминаний (08:00 / 16:00) ---
CRON_TZ=Europe/Moscow

# --- Домен для Caddy/HTTPS (нужна A-запись DOMAIN → IP сервера) ---
DOMAIN=drive.van-mark.ru

# --- Геокодер адресов (оценка времени на дорогу, PRD §14). На проде рекомендуется dadata. ---
# nominatim — бесплатно без ключа (лимит ~1 запрос/с, нужен User-Agent); none — выключить.
GEOCODER_PROVIDER=nominatim
GEOCODER_USER_AGENT="vanmark-drive/1.0 (dispatch service)"
# Для dadata — ключ и секрет из личного кабинета dadata.ru (пусто при nominatim/none):
DADATA_API_KEY=
DADATA_SECRET=

# --- TWA (Android-приложение, docs/TWA.md). Заполнить ПОСЛЕ сборки APK — иначе приложение
#     откроется с адресной строкой (verified-TWA отвалится). ---
TWA_PACKAGE_NAME=ru.vmdrive.twa
TWA_SHA256_FINGERPRINT=

# --- Off-site бэкап (deploy/backup.sh + deploy/cron.d/vanmark-backup). КРИТИЧНО (preflight-аудит В5):
#     без этих переменных бэкап ТОЛЬКО локальный (на том же VPS) — потеря сервера = потеря бэкапов. ---
# Назначение (одно из): S3 (Timeweb/любой S3-совместимый) либо rclone-remote.
# BACKUP_S3_URI=s3://vanmark-backups/db
# BACKUP_S3_ENDPOINT=https://s3.twcstorage.ru
# AWS_ACCESS_KEY_ID=__ключ_S3__
# AWS_SECRET_ACCESS_KEY=__секрет_S3__
# Шифрование ПДн перед выгрузкой (ОБЯЗАТЕЛЬНО для off-site): публичный age-ключ; приватный держать ВНЕ сервера.
# BACKUP_AGE_RECIPIENT=age1...
# BACKUP_RETENTION_DAYS=14
